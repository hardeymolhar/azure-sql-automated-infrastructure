# .editorconfig - Consistent formatting across editors
root = true

[*]
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
charset = utf-8

[*.{yml,yaml}]
indent_style = space
indent_size = 2

[*.{j2,jinja2}]
indent_style = space
indent_size = 2

[Makefile]
indent_style = tab